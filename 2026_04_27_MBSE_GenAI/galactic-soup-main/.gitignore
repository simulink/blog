# Simulink cache and codegen outputs (regenerated by buildAll)
derived/cache/*
!derived/cache/.gitkeep
derived/codegen/*
!derived/codegen/.gitkeep

# Simulink / Stateflow build directories that can appear anywhere
slprj/
sfprj/
_SFprj/

# MATLAB auto-save and backup
*.asv
*.autosave
*.slxc

# Compiled MEX
*.mex*

# MATLAB-Test-host local profile outputs
*.mldatx~

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*~
